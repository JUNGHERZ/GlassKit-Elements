{
  "name": "@jungherz-de/glasskit-elements",
  "version": "0.9.0",
  "description": "Vanilla JavaScript Web Components wrapping the GlassKit CSS glassmorphism library",
  "license": "MIT",
  "homepage": "https://glasskit-elements.jungherz.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/JUNGHERZ/glasskit-elements.git"
  },
  "bugs": {
    "url": "https://github.com/JUNGHERZ/glasskit-elements/issues"
  },
  "type": "module",
  "main": "dist/glasskit-elements.js",
  "module": "dist/glasskit-elements.esm.js",
  "exports": {
    ".": {
      "import": "./dist/glasskit-elements.esm.js",
      "default": "./dist/glasskit-elements.js"
    },
    "./components/*": "./dist/components/*.js"
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "serve": "npx serve ."
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "glassmorphism",
    "glasskit",
    "ui-components",
    "vanilla-js"
  ],
  "peerDependencies": {
    "@jungherz-de/glasskit": ">=1.4.0"
  },
  "devDependencies": {
    "@jungherz-de/glasskit": "^1.4.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0"
  }
}
